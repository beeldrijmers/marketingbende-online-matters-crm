POSTMARK_WEBHOOK_USER=testuser
POSTMARK_WEBHOOK_PASSWORD=testpwd
VITE_INBOUND_EMAIL=2aff30e603e54dc3eb556bd9e03ee099@inbound.postmarkapp.com

# IPs can be found at https://postmarkapp.com/support/article/800-ips-for-firewalls#webhooks
# 172.18.0.1, 172.19.0.1 and 172.20.0.1 are for local dev only
# 192.168.65.1 is for Docker Desktop on Mac
POSTMARK_WEBHOOK_AUTHORIZED_IPS=3.134.147.250,50.31.156.6,50.31.156.77,18.217.206.57,172.18.0.1,172.19.0.1,192.168.65.1,172.20.0.1

SB_JWT_ISSUER=http://127.0.0.1:54321/auth/v1
SB_PUBLISHABLE_KEY=sb_publishable_ACJWlzQHlZjBrEguHvfOxg_3BJgxAaH

# Public URL of the CRM app — used by the task-list MCP App to link
# contact names back to the CRM. Leave empty to render names as plain text.
CRM_BASE_URL=http://localhost:5173

# Trello sync (supabase/functions/trello-sync). New deals/companies created
# from Trello cards are attributed to this sales user, since Trello card
# members don't reliably map to CRM accounts.
TRELLO_SYNC_DEFAULT_SALES_EMAIL=info@marketingbende.nl

# Local-only shared secret checked against the "?secret=" query param on the
# webhook callback URL. Not a real secret in production — replace it with a
# long random value before registering the real Trello webhook, and never
# commit that production value here.
TRELLO_WEBHOOK_SHARED_SECRET=local-dev-secret

# TRELLO_API_KEY and TRELLO_TOKEN are real third-party credentials (unlike
# the other values in this file, which only work against the local dev
# stack) and must NOT be committed. Export them in your shell before running
# `make start-supabase-functions` if you need to test the live Trello-fetch
# path locally, e.g.:
#   export TRELLO_API_KEY=... TRELLO_TOKEN=...
#   npx supabase functions serve --env-file supabase/functions/.env
# TRELLO_API_SECRET (optional): enables Trello's official HMAC signature
# check in addition to the shared secret above. Found next to the API key on
# https://trello.com/power-ups/admin. Also must not be committed.
